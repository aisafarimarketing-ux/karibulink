# KaribuLink — local environment overrides.
#
# Copy this file to `.env.local` and fill in the values. Both Fair
# Mode lead capture and the /admin/fair-leads dashboard fall back to
# localStorage when these are missing, so the app still runs locally
# without Supabase.

# Supabase project URL (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
